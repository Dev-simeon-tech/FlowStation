{
  "name": "flowstation",
  "private": true,
  "workspaces": [
    "apps/client",
    "apps/server",
    "packages/shared"
  ],
  "scripts": {
    "client": "npm run dev --workspace=apps/client",
    "server": "npm run dev --workspace=apps/server",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
